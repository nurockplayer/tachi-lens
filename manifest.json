{
  "manifest_version": 3,
  "name": "tachi-lens",
  "version": "0.1.0.1",
  "version_name": "0.2.0-beta.1",
  "default_locale": "en",
  "description": "Twitch 聊天室沉浸式翻譯 — 支援 Gemini、DeepSeek、OpenAI、Claude",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.twitch.tv/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.twitch.tv/*"],
      "js": ["src/content/twitch-entry.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "tachi-lens"
  },
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Ctrl+Shift+T"
      },
      "description": "Toggle translation on/off"
    },
    "toggle-display-mode": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      },
      "description": "Cycle display mode (below → hover → collapse)"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
