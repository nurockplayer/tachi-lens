{
  "name": "tachi-lens",
  "version": "0.1.0",
  "private": true,
  "description": "Twitch 聊天室沉浸式翻譯 Chrome Extension",
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build && node scripts/check-popup.mjs",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0",
    "vite": "^7.3.6",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
